# LLM API (Poe - minimax-m2.7)
POE_API_KEY=your_poe_api_key_here
POE_API_URL=https://api.poe.com/v1/chat/completions
POE_MODEL=minimax-m2.7

# Embedding API (SiliconFlow - bge-m3)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/embeddings
SILICONFLOW_MODEL=BAAI/bge-m3

# Agent SDK (local CCR Anthropic-compatible protocol bridge)
ANTHROPIC_BASE_URL=http://127.0.0.1:3456
ANTHROPIC_AUTH_TOKEN=your_anthropic_or_agent_auth_token_here
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=kimi-k2.5
ANTHROPIC_DEFAULT_SONNET_MODEL=kimi-k2.5
ANTHROPIC_DEFAULT_OPUS_MODEL=kimi-k2.5
ANTHROPIC_DEFAULT_HAIKU_MODEL=kimi-k2.5

# Legacy fallback only; prefer ANTHROPIC_* above for Claude Agent SDK.
KIMI_API_URL=https://api.kimi.com/coding/
KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=kimi-k2.5

# Knowledge graph
KG_DEFAULT_OUTPUT_DIR=data/processed
VECTOR_DB_PATH=data/vector_db

# PubMed
PUBMED_MAX_RESULTS=10

# Logging
LOG_LEVEL=INFO
